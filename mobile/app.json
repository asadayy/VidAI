{
  "expo": {
    "name": "VidAI",
    "slug": "vidai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "vidai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0a10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vidai.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vidai.app",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D7385E"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow VidAI to save invitation images to your gallery.",
          "savePhotosPermission": "Allow VidAI to save invitation images to your gallery.",
          "isAccessMediaLocationEnabled": true,
          "isAudioEnabled": false
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "https://stick-hungrily-jaundice.ngrok-free.dev/api/v1",
      "router": {},
      "eas": {
        "projectId": "620ece0f-2a95-461e-99b3-f618ce722d1d"
      }
    }
  }
}
