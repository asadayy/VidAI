# ============================================
# VidAI Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- MongoDB Atlas ---
# Go to Atlas > Database > Connect > Drivers > Copy connection string
# Replace <username>, <password>, and <dbname> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vidai?retryWrites=true&w=majority

# --- JWT Authentication ---
# Generate two separate secure secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANT: Use DIFFERENT secrets for access and refresh tokens
JWT_SECRET=GENERATE_A_SECURE_512_BIT_SECRET_FOR_ACCESS_TOKENS
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_SECURE_512_BIT_SECRET_FOR_REFRESH_TOKENS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# --- Stripe Payment Gateway ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Cloudinary (Image/Media Storage) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- SendGrid (Email Service) ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@vidai.pk
SENDGRID_FROM_NAME=VidAI

# --- AI Microservice ---
AI_SERVICE_URL=http://localhost:8000

# --- Frontend URL (for CORS) ---
CLIENT_URL=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
